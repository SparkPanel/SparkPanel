# SparkPanel Backend .env example
# Copy to backend/.env and adjust values

# Server
PORT=8080
NODE_ENV=development

# IMPORTANT: set to your VDS IP/domain in production (NOT localhost)
# For example: BASE_URL=http://203.0.113.10:5173, API_BASE_URL=http://203.0.113.10:8080
BASE_URL=http://localhost:5173
API_BASE_URL=http://localhost:8080

# Database (PostgreSQL)
# Example for local docker-compose postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sparkpanel?schema=public

# JWT
# Use strong random secrets in production
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# SMTP (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=SparkPanel <no-reply@sparkpanel.local>

# Server data path (host folder)
FILES_ROOT=/var/lib/sparkpanel/servers

# Disk quotas
DISK_QUOTA_ENFORCE=false
DISK_QUOTA_DEFAULT_MB=10240

# Backup retention policy
BACKUP_RETENTION_DAYS=14
BACKUP_RETENTION_MAX=10

# S3 backups (optional)
S3_ENABLED=false
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_SSE=
S3_PATH_STYLE=false

# Bootstrap admin (optional)
ADMIN_EMAIL=
ADMIN_PASSWORD=